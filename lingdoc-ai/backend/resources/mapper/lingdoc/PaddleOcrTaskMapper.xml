<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.lingdoc.PaddleOcrTaskMapper">
    
    <resultMap type="com.ruoyi.system.domain.lingdoc.PaddleOcrTask" id="PaddleOcrTaskResult">
        <result property="taskId" column="task_id"/>
        <result property="userId" column="user_id"/>
        <result property="taskName" column="task_name"/>
        <result property="fileUrl" column="file_url"/>
        <result property="fileName" column="file_name"/>
        <result property="fileType" column="file_type"/>
        <result property="status" column="status"/>
        <result property="resultJson" column="result_json"/>
        <result property="pageCount" column="page_count"/>
        <result property="processTime" column="process_time"/>
        <result property="avgPageTime" column="avg_page_time"/>
        <result property="charCount" column="char_count"/>
        <result property="errorMsg" column="error_msg"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectPaddleOcrTaskVo">
        select task_id, user_id, task_name, file_url, file_name, file_type,
               status, result_json, page_count, process_time, avg_page_time,
               char_count, error_msg, create_by, create_time, update_by, update_time, remark
        from lingdoc_ocr_task
    </sql>

    <select id="selectPaddleOcrTaskById" parameterType="String" resultMap="PaddleOcrTaskResult">
        <include refid="selectPaddleOcrTaskVo"/>
        where task_id = #{taskId}
    </select>

    <select id="selectPaddleOcrTaskList" parameterType="com.ruoyi.system.domain.lingdoc.PaddleOcrTask" resultMap="PaddleOcrTaskResult">
        <include refid="selectPaddleOcrTaskVo"/>
        <where>
            <if test="userId != null"> and user_id = #{userId}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
            <if test="taskName != null  and taskName != ''">
                AND task_name like concat('%', #{taskName}, '%')
            </if>
            <if test="fileType != null  and fileType != ''"> and file_type = #{fileType}</if>
        </where>
        order by create_time desc
    </select>
    
    <insert id="insertPaddleOcrTask" parameterType="com.ruoyi.system.domain.lingdoc.PaddleOcrTask">
        insert into lingdoc_ocr_task
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="taskId != null">task_id,</if>
            <if test="userId != null">user_id,</if>
            <if test="taskName != null">task_name,</if>
            <if test="fileUrl != null">file_url,</if>
            <if test="fileName != null">file_name,</if>
            <if test="fileType != null">file_type,</if>
            <if test="status != null">status,</if>
            <if test="resultJson != null">result_json,</if>
            <if test="pageCount != null">page_count,</if>
            <if test="processTime != null">process_time,</if>
            <if test="avgPageTime != null">avg_page_time,</if>
            <if test="charCount != null">char_count,</if>
            <if test="errorMsg != null">error_msg,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="taskId != null">#{taskId},</if>
            <if test="userId != null">#{userId},</if>
            <if test="taskName != null">#{taskName},</if>
            <if test="fileUrl != null">#{fileUrl},</if>
            <if test="fileName != null">#{fileName},</if>
            <if test="fileType != null">#{fileType},</if>
            <if test="status != null">#{status},</if>
            <if test="resultJson != null">#{resultJson},</if>
            <if test="pageCount != null">#{pageCount},</if>
            <if test="processTime != null">#{processTime},</if>
            <if test="avgPageTime != null">#{avgPageTime},</if>
            <if test="charCount != null">#{charCount},</if>
            <if test="errorMsg != null">#{errorMsg},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updatePaddleOcrTask" parameterType="com.ruoyi.system.domain.lingdoc.PaddleOcrTask">
        update lingdoc_ocr_task
        <trim prefix="SET" suffixOverrides=",">
            <if test="userId != null">user_id = #{userId},</if>
            <if test="taskName != null">task_name = #{taskName},</if>
            <if test="fileUrl != null">file_url = #{fileUrl},</if>
            <if test="fileName != null">file_name = #{fileName},</if>
            <if test="fileType != null">file_type = #{fileType},</if>
            <if test="status != null">status = #{status},</if>
            <if test="resultJson != null">result_json = #{resultJson},</if>
            <if test="pageCount != null">page_count = #{pageCount},</if>
            <if test="processTime != null">process_time = #{processTime},</if>
            <if test="avgPageTime != null">avg_page_time = #{avgPageTime},</if>
            <if test="charCount != null">char_count = #{charCount},</if>
            <if test="errorMsg != null">error_msg = #{errorMsg},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where task_id = #{taskId}
    </update>

    <delete id="deletePaddleOcrTaskById" parameterType="String">
        delete from lingdoc_ocr_task where task_id = #{taskId}
    </delete>

    <delete id="deletePaddleOcrTaskByIds" parameterType="String">
        delete from lingdoc_ocr_task where task_id in 
        <foreach collection="array" item="taskId" open="(" separator="," close=")">
            #{taskId}
        </foreach>
    </delete>
</mapper>