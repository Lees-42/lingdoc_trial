# =============================================================================
# LingDoc AI Service - Environment Variables Example
# =============================================================================
# 说明：本文件是环境变量模板，包含所有可配置项的说明
# 使用方式：复制为 .env 文件，填入真实值，部署时加载
# 安全警告：.env 文件包含敏感信息，切勿提交到 Git！已加入 .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# 必填配置（没有这些服务无法启动）
# ---------------------------------------------------------------------------

# 阿里云 DashScope API Key（调用 Qwen3-Max 大模型）
# 获取地址：https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=sk-1786cb3f70ef4291a5514430cde941f8

# 主后端与 AI 服务之间的共享密钥（认证用）
# 主后端每次请求必须在 Header 中携带：X-Internal-Token: {此值}
# 安全建议：生产环境使用 32 位以上随机字符串
AI_INTERNAL_TOKEN=lingdoc-ai-2026-a7f3e9d2b8c1e4f5

# ---------------------------------------------------------------------------
# 可选配置（有默认值，可按需调整）
# ---------------------------------------------------------------------------

# AI 服务监听端口（默认 8000）
AI_SERVICE_PORT=8000

# 服务绑定主机（Docker 用 0.0.0.0，本地开发用 127.0.0.1）
AI_SERVICE_HOST=0.0.0.0

# 默认大模型（qwen3-max 性能最强，qwen3-30b-a3b 性价比高）
AI_DEFAULT_MODEL=qwen3-max

# LLM 调用超时（秒），长文档建议 ≥ 60
AI_LLM_TIMEOUT=60

# OCR 配置
AI_PDF_DPI=150           # PDF 转图片 DPI（越大越清晰，越慢）
AI_OCR_THRESHOLD=0.5     # OCR 置信度阈值（0.0-1.0）
AI_OCR_LANGUAGE=ch       # 识别语言：ch=中文+英文，en=英文

# 文件存储路径（必须和主后端挂载同一个目录）
AI_UPLOAD_DIR=/tmp/lingdoc/uploads    # 主后端上传的文件保存位置
AI_OUTPUT_DIR=/tmp/lingdoc/output    # AI 处理结果缓存位置

# 日志级别（DEBUG/INFO/WARNING/ERROR）
AI_LOG_LEVEL=INFO
