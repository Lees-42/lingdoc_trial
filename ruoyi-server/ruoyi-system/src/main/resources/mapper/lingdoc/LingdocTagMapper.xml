<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.lingdoc.LingdocTagMapper">

    <resultMap type="com.ruoyi.system.domain.lingdoc.LingdocTag" id="LingdocTagResult">
        <result property="tagId" column="tag_id"/>
        <result property="tagName" column="tag_name"/>
        <result property="tagColor" column="tag_color"/>
        <result property="tagScope" column="tag_scope"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <sql id="selectLingdocTagVo">
        select tag_id, tag_name, tag_color, tag_scope, sort_order, create_time
        from lingdoc_tag
    </sql>

    <select id="selectLingdocTagById" parameterType="String" resultMap="LingdocTagResult">
        <include refid="selectLingdocTagVo"/>
        where tag_id = #{tagId}
    </select>

    <select id="selectLingdocTagList" parameterType="com.ruoyi.system.domain.lingdoc.LingdocTag" resultMap="LingdocTagResult">
        <include refid="selectLingdocTagVo"/>
        <where>
            <if test="tagName != null and tagName != ''"> and tag_name like concat('%', #{tagName}, '%')</if>
            <if test="tagScope != null and tagScope != ''"> and tag_scope = #{tagScope}</if>
        </where>
        order by sort_order asc, create_time desc
    </select>

    <select id="selectLingdocTagByName" parameterType="String" resultMap="LingdocTagResult">
        <include refid="selectLingdocTagVo"/>
        where tag_name = #{tagName}
    </select>

    <insert id="insertLingdocTag" parameterType="com.ruoyi.system.domain.lingdoc.LingdocTag">
        insert into lingdoc_tag
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="tagId != null">tag_id,</if>
            <if test="tagName != null">tag_name,</if>
            <if test="tagColor != null">tag_color,</if>
            <if test="tagScope != null">tag_scope,</if>
            <if test="sortOrder != null">sort_order,</if>
            <if test="createTime != null">create_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="tagId != null">#{tagId},</if>
            <if test="tagName != null">#{tagName},</if>
            <if test="tagColor != null">#{tagColor},</if>
            <if test="tagScope != null">#{tagScope},</if>
            <if test="sortOrder != null">#{sortOrder},</if>
            <if test="createTime != null">#{createTime},</if>
        </trim>
    </insert>

    <update id="updateLingdocTag" parameterType="com.ruoyi.system.domain.lingdoc.LingdocTag">
        update lingdoc_tag
        <trim prefix="SET" suffixOverrides=",">
            <if test="tagName != null">tag_name = #{tagName},</if>
            <if test="tagColor != null">tag_color = #{tagColor},</if>
            <if test="tagScope != null">tag_scope = #{tagScope},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
        </trim>
        where tag_id = #{tagId}
    </update>

    <delete id="deleteLingdocTagById" parameterType="String">
        delete from lingdoc_tag where tag_id = #{tagId}
    </delete>

    <delete id="deleteLingdocTagByIds" parameterType="String">
        delete from lingdoc_tag where tag_id in
        <foreach collection="array" item="tagId" open="(" separator="," close=")">
            #{tagId}
        </foreach>
    </delete>

</mapper>
